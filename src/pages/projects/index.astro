---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  return b.data.year - a.data.year;
});
---

<BaseLayout title="Projects" description="Selected projects by Emil Østergaard.">
  <header class="page-header">
    <h1>Projects</h1>
    <p>A selection of things I've built or contributed to.</p>
  </header>

  {
    projects.length === 0 ? (
      <p class="empty">No projects listed yet.</p>
    ) : (
      <ul class="project-list">
        {projects.map((project) => (
          <li class="project">
            <div class="project__meta">
              <span class="project__year">{project.data.year}</span>
            </div>
            <div class="project__body">
              <h2 class="project__title">
                {project.data.link ? (
                  <a href={project.data.link} rel="noopener noreferrer" target="_blank">
                    {project.data.title}
                  </a>
                ) : (
                  project.data.title
                )}
              </h2>
              <p class="project__description">{project.data.description}</p>
              {(project.data.role || project.data.repo) && (
                <p class="project__footer">
                  {project.data.role && <span>{project.data.role}</span>}
                  {project.data.role && project.data.repo && (
                    <span class="sep" aria-hidden="true">
                      ·
                    </span>
                  )}
                  {project.data.repo && (
                    <a href={project.data.repo} rel="noopener noreferrer" target="_blank">
                      Source
                    </a>
                  )}
                </p>
              )}
            </div>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

<style>
  .page-header {
    margin: var(--space-4) 0 var(--space-16);
  }
  .page-header p {
    color: var(--color-text-muted);
    margin: 0;
  }

  .project-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .project {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-6);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-rule);
  }

  .project:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  .project__year {
    font-size: var(--text-sm);
    color: var(--color-text-faint);
    font-variant-numeric: tabular-nums;
    padding-top: 0.3em;
  }

  .project__title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2);
  }

  .project__title a {
    text-decoration-color: var(--color-rule);
  }

  .project__description {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-2);
  }

  .project__footer {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .project__footer .sep {
    margin: 0 var(--space-2);
    color: var(--color-text-faint);
  }

  .empty {
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .project {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
    .project__year {
      padding-top: 0;
    }
  }
</style>
