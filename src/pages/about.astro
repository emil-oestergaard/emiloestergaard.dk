---
import ProseLayout from '../layouts/ProseLayout.astro';
import { SITE } from '../consts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  email: `mailto:${SITE.author.email}`,
  sameAs: [SITE.author.github, SITE.author.linkedin],
  jobTitle: 'Software Engineer',
};
---

<ProseLayout
  title="About"
  description="About Emil Østergaard — background, current work, and how to get in touch."
  jsonLd={jsonLd}
>
  <p>
    I'm a software engineer based in Copenhagen. I care about systems that are
    legible, durable, and pleasant to use.
  </p>

  <h2>Now</h2>
  <p>
    Currently exploring applied AI tooling, developer experience, and the parts of
    a product where craft still matters.
  </p>

  <h2>Background</h2>
  <ul>
    <li>
      <strong>Engineering</strong> — product and infrastructure work across startups
      and larger teams.
    </li>
    <li>
      <strong>Writing</strong> — occasional essays on the craft of building software.
    </li>
  </ul>

  <h2>Elsewhere</h2>
  <ul>
    <li><a href="mailto:emiloestergaard03@proton.me">Email</a></li>
    <li><a href="https://github.com/emil-oestergaard/" rel="me noopener noreferrer" target="_blank">GitHub</a></li>
    <li><a href="https://www.linkedin.com/in/emil-%C3%B8stergaard-0671472a5/" rel="me noopener noreferrer" target="_blank">LinkedIn</a></li>
  </ul>
</ProseLayout>
