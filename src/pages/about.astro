---
import ProseLayout from '../layouts/ProseLayout.astro';
import { SITE } from '../consts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  email: `mailto:${SITE.author.email}`,
  sameAs: [SITE.author.github, SITE.author.linkedin],
  jobTitle: 'AI Engineer',
  worksFor: {
    '@type': 'Organization',
    name: 'umage.ai',
    url: 'https://umage.ai',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'University of Copenhagen',
    url: 'https://www.ku.dk',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Copenhagen',
    addressCountry: 'DK',
  },
  knowsLanguage: ['da', 'en', 'ru', 'de'],
};
---

<ProseLayout
  title="About"
  description="About Emil Østergaard — Computer Science student at the University of Copenhagen and AI Engineer at umage.ai."
  jsonLd={jsonLd}
>
  <p>
    I'm a Computer Science student at the University of Copenhagen and an AI Engineer at
    <a href="https://umage.ai" rel="noopener noreferrer" target="_blank">umage.ai</a>. Before that,
    I spent two and a half years at IT Instituttet as a full-stack developer — first as a
    freelancer, then full-time.
  </p>

  <p>
    I care about systems that are legible, durable, and pleasant to use — the kind of software where
    complexity lives in the right place and a careful reader can follow how the pieces fit together.
  </p>

  <p>
    What I'm actively working on lives on the <a href="/now">/now</a> page.
  </p>

  <h2>Work</h2>
  <ul>
    <li>
      <strong>umage.ai</strong> — AI Engineer, Apr 2026 – present. Building AI-driven platforms and helping
      the team transition from a legacy full-stack product toward AI-first infrastructure.
    </li>
    <li>
      <strong>IT Instituttet</strong> — Junior Software & Full-Stack Developer, Oct 2023 – Apr 2026. C#
      / .NET, Angular, React, and Azure DevOps. Grew from freelance into a full-time role maintaining
      mission-critical systems and business infrastructure.
    </li>
    <li>
      <strong>SPAR Birkerød</strong> — Sales Assistant & Shift Leader, 2021 – 2023. Ran evening store
      operations independently shortly after turning 18.
    </li>
  </ul>

  <h2>Education</h2>
  <ul>
    <li>
      <strong>University of Copenhagen</strong> — BSc in Computer Science (Datalogi), 2023 – present.
      Top grade (12/A) in Software Development, Linear Algebra, Mathematical Analysis and Probability
      Theory, Modelling and Analysis of Data, Participatory Design, and Algorithms and Data Structures.
    </li>
    <li>
      <strong>Birkerød Gymnasium</strong> — STX Graduate, Mathematics and Physics, 2021 – 2023.
    </li>
  </ul>

  <h2>Projects</h2>
  <p>A few things I've built in the evenings for the pleasure of understanding them:</p>
  <ul>
    <li>
      <strong>HTTP server in C</strong> — functional HTTP server running on a Raspberry Pi, for understanding
      sockets and manual memory management.
    </li>
    <li>
      <strong>Distributed key-value store in Go</strong> — persistent store exploring concurrency with
      goroutines and data consistency.
    </li>
    <li>
      <strong>Search engine in Python</strong> — small-scale engine with custom indexing and ranking.
    </li>
  </ul>
  <p>
    More of what I'm proud of lives on <a href="/projects">/projects</a>.
  </p>

  <h2>Languages</h2>
  <p>
    I speak <strong>Danish</strong> (native), <strong>English</strong> (C2),
    <strong>Russian</strong> (proficient), and <strong>German</strong> (proficient).
  </p>
  <p>
    I code in <strong>C</strong>, <strong>C++</strong>, <strong>C#</strong>, <strong>Rust</strong>,
    <strong>Go</strong>, <strong>Python</strong>, and <strong>TypeScript</strong>.
  </p>

  <h2>Certifications</h2>
  <ul>
    <li>Harvard CS50 (2024)</li>
    <li>Google Generative AI (2024)</li>
    <li>Microsoft Certified: Foundational C# (2023)</li>
    <li>Cambridge First Certificate in English (2019)</li>
  </ul>

