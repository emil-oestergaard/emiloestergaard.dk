---
import BaseLayout from './BaseLayout.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  heroImage?: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown>;
  readingMinutes?: number;
  tags?: readonly string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  canonicalPath,
  jsonLd: jsonLdOverride,
  readingMinutes,
  tags = [],
} = Astro.props;

const formattedDate = pubDate
  ? pubDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const siteOrigin = Astro.site ?? new URL(SITE.url);
const canonical = new URL(canonicalPath ?? Astro.url.pathname, siteOrigin);

const jsonLd =
  jsonLdOverride ??
  (pubDate
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: pubDate.toISOString(),
        ...(updatedDate && { dateModified: updatedDate.toISOString() }),
        author: {
          '@type': 'Person',
          name: SITE.author.name,
          url: SITE.url,
        },
        publisher: {
          '@type': 'Person',
          name: SITE.author.name,
          url: SITE.url,
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': canonical.toString(),
        },
        ...(heroImage && { image: new URL(heroImage, siteOrigin).toString() }),
      }
    : undefined);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  image={heroImage}
  type={pubDate ? 'article' : 'website'}
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  jsonLd={jsonLd}
>
  <article class="prose">
    <header class="prose__header">
      <h1>{title}</h1>
      {
        formattedDate && (
          <p class="prose__meta">
            <time datetime={pubDate!.toISOString()}>{formattedDate}</time>
            {readingMinutes !== undefined && (
              <>
                <span class="sep" aria-hidden="true">
                  ·
                </span>
                <span>{readingMinutes} min read</span>
              </>
            )}
            {updatedDate && (
              <>
                <span class="sep" aria-hidden="true">
                  ·
                </span>
                <span>
                  Updated{' '}
                  <time datetime={updatedDate.toISOString()}>
                    {updatedDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                </span>
              </>
            )}
          </p>
        )
      }
    </header>
    <div class="prose__body">
      <slot />
    </div>
    {
      tags.length > 0 && (
        <footer class="prose__tags">
          <ul>
            {tags.map((tag) => (
              <li>
                <a href={`/writing/tags/${tag}/`}>#{tag}</a>
              </li>
            ))}
          </ul>
        </footer>
      )
    }
    <slot name="post-nav" />
  </article>
</BaseLayout>

<style>
  .prose {
    padding-top: var(--space-4);
  }

  .prose__header {
    margin-bottom: var(--space-12);
  }

  .prose__header h1 {
    margin-bottom: var(--space-3);
  }

  .prose__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .prose__meta .sep {
    margin: 0 var(--space-2);
    color: var(--color-text-faint);
  }

  .prose__body :global(h2:first-child),
  .prose__body :global(h3:first-child) {
    margin-top: 0;
  }

  .prose__tags {
    margin: var(--space-12) 0 0;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-rule);
  }

  .prose__tags ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .prose__tags li {
    margin: 0;
  }

  .prose__tags a {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .prose__tags a:hover {
    color: var(--color-text);
  }
</style>
