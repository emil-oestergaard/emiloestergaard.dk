# /etc/caddy/Caddyfile
#
# Caddy auto-provisions Let's Encrypt certificates once DNS points at the
# server and ports 80 and 443 are reachable. Reload after edits:
#   sudo systemctl reload caddy
# Follow logs with:
#   journalctl -u caddy -f

{
	# Email for Let's Encrypt expiry warnings. Required for real deployments.
	email emiloestergaard03@proton.me

	# Uncomment while testing to avoid rate limits on the production CA:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Canonical apex host
emiloestergaard.dk {
	root * /var/www/emiloestergaard.dk
	encode zstd gzip
	file_server

	# Astro emits hashed assets under /_astro/. Cache them aggressively —
	# their filenames change on every build, so stale clients can't hurt.
	@hashed path /_astro/*
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# HTML should revalidate each request so deploys propagate quickly.
	@html path *.html /
	header @html Cache-Control "public, max-age=0, must-revalidate"

	# Security headers applied to every response.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Caddy advertises itself by default. Strip it.
		-Server
	}

	# Pretty 404s: serve /404.html for anything that doesn't resolve.
	handle_errors {
		@notfound expression {err.status_code} == 404
		rewrite @notfound /404.html
		file_server
	}

	log {
		output file /var/log/caddy/emiloestergaard.dk.log {
			roll_size 10mb
			roll_keep 7
		}
		format json
	}
}

# Redirect www → apex. Cheapest way to keep canonical URLs clean.
www.emiloestergaard.dk {
	redir https://emiloestergaard.dk{uri} permanent
}
