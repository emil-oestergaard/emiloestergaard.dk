# /etc/nginx/sites-available/emiloestergaard.dk
#
# Enable:   sudo ln -s ../sites-available/emiloestergaard.dk /etc/nginx/sites-enabled/
# Verify:   sudo nginx -t
# Reload:   sudo systemctl reload nginx
#
# After this file is in place, run:
#   sudo certbot --nginx -d emiloestergaard.dk -d www.emiloestergaard.dk \
#     --agree-tos -m emiloestergaard03@proton.me --non-interactive
#
# Certbot will inject ssl_certificate / ssl_certificate_key directives into
# the :443 server blocks and install a systemd timer that renews every
# ~60 days. Check it with: systemctl list-timers | grep certbot.

# --- HTTP: redirect everything except ACME challenges to HTTPS ---
server {
    listen 80;
    listen [::]:80;
    server_name emiloestergaard.dk www.emiloestergaard.dk;

    # Certbot's HTTP-01 challenge lands here before the redirect.
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# --- HTTPS: www → apex redirect ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.emiloestergaard.dk;
    # certbot injects ssl_certificate lines here

    return 301 https://emiloestergaard.dk$request_uri;
}

# --- HTTPS: the real vhost ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name emiloestergaard.dk;
    # certbot injects ssl_certificate lines here

    # Serve from the `current` symlink. deploy/server/release-swap.sh
    # atomically repoints it at the newest release.
    root /var/www/emiloestergaard.dk/current;
    index index.html;

    # Compress text responses on the wire.
    gzip on;
    gzip_vary on;
    gzip_min_length 256;
    gzip_types
        text/plain
        text/css
        text/xml
        application/xml
        application/xml+rss
        application/json
        application/javascript
        image/svg+xml;

    # Astro emits hashed assets under /_astro/. Long-cache them hard —
    # filenames change every build so stale caches can't hurt.
    location /_astro/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    # Everything else: short cache, Astro's trailing-slash URLs work via
    # the $uri/ and $uri.html fallbacks.
    location / {
        add_header Cache-Control "public, max-age=0, must-revalidate";
        try_files $uri $uri/ $uri.html =404;
    }

    # Security headers — applied to every response, always.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Pretty 404s.
    error_page 404 /404.html;

    access_log /var/log/nginx/emiloestergaard.dk.access.log;
    error_log  /var/log/nginx/emiloestergaard.dk.error.log;
}
