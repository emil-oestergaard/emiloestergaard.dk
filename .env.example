# Cloudflare Web Analytics token. Optional.
# If set, a single beacon script is injected on every page (cookieless, GDPR-friendly).
# Get one at: https://dash.cloudflare.com/?to=/:account/web-analytics
# Leave unset to keep the site fully unmeasured.
PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# Deployment — consumed by deploy/deploy.sh (rsync over SSH).
# Set on your local machine, not committed. See deploy/README.md.
DEPLOY_HOST=
DEPLOY_USER=deploy
DEPLOY_PATH=/var/www/emiloestergaard.dk
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519
